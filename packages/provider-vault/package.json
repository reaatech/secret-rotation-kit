{
  "name": "@reaatech/secret-rotation-provider-vault",
  "version": "0.1.0",
  "description": "HashiCorp Vault provider for Secret Rotation Kit",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/secret-rotation-kit.git",
    "directory": "packages/provider-vault"
  },
  "homepage": "https://github.com/reaatech/secret-rotation-kit/tree/main/packages/provider-vault#readme",
  "bugs": {
    "url": "https://github.com/reaatech/secret-rotation-kit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/secret-rotation-types": "workspace:*"
  },
  "peerDependencies": {
    "node-vault": "^0.10.0"
  },
  "peerDependenciesMeta": {
    "node-vault": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.1"
  }
}
